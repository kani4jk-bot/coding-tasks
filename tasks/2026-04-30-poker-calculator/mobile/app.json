{
  "expo": {
    "name": "Poker Calculator",
    "slug": "poker-calculator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050e08"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kani4jkbot.pokercalculator",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan and identify playing cards on the board.",
        "NSPhotoLibraryUsageDescription": "Used to select photos of playing cards."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050e08"
      },
      "package": "com.kani4jkbot.pokercalculator",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Used to select photos of playing cards.",
          "cameraPermission": "Used to scan and identify playing cards on the board."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "64a919d8-9535-4c0c-b10e-1656bba05377"
      }
    }
  }
}