{
  "expo": {
    "name": "Plant ID",
    "slug": "plant-id",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#14532d"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kani.plantid",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Plant ID uses your camera to photograph plants for identification.",
        "NSPhotoLibraryUsageDescription": "Plant ID uses your photo library to select plant photos for identification."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#14532d"
      },
      "package": "com.kani.plantid",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "9a25eba8-106d-4c61-b8ac-cfaeb4e7f164"
      }
    },
    "owner": "camputy",
    "updates": {
      "url": "https://u.expo.dev/9a25eba8-106d-4c61-b8ac-cfaeb4e7f164",
      "checkAutomatically": "ON_LOAD"
    }
  }
}
